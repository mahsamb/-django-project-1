{
  "name": "django-project-1",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "postCreateCommand": "pip install -r requirements.txt && python manage.py migrate && python manage.py seed_data --per-file 2",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Django App",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
